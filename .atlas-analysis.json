  "keyFeatures": [
    "Quran reading with Arabic text, French translation, and Wolof translation",
    "Accurate prayer times based on geolocation with notifications",
    "Comprehensive Hadith collections (Sahih Bukhari, Muslim, and more)",
    "Audio recitations from multiple Qaris with playback controls",
    "Qibla direction finder using device sensors",
    "Dhikr counter and Islamic supplications",
    "Favorites management for verses and Hadiths",
    "Live streaming from Masjid Al-Haram and Masjid Al-Nabawi"
  ],
  "publicApiSurface": [
    "quranService.getSuraNames()",
    "quranService.getSuraTranslation(suraNumber)",
    "quranService.getAyaTranslation(suraNumber, ayaNumber)",
    "prayerTimesService.getUserLocation()",
    "prayerTimesService.getPrayerTimesByCoords(latitude, longitude)",
    "prayerTimesService.schedulePrayerTimeNotifications(prayerTimes)",
    "hadithService.getCollectionsList()",
    "hadithService.loadCollection(collectionName, language)",
    "hadithService.searchHadith(query, collectionName)",
    "notificationService.requestPermissions()",
    "notificationService.scheduleAllPrayerNotifications(times)",
    "aladhanService.getPrayerTimes(latitude, longitude)",
    "aladhanService.getCurrentHijriDate()"
  ]
}
